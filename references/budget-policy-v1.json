{
  "policy_version": "budget-policy-v1",
  "profiles": {
    "focused": {
      "max_search_branches": 2,
      "results_per_branch": 15,
      "max_extraction_attempts": 8,
      "max_successful_extractions": 6,
      "max_adaptive_cycles": 2,
      "max_llm_calls": 6,
      "max_input_tokens": 32768,
      "max_output_tokens": 8192,
      "max_retrieval_candidates": 40,
      "max_reranker_candidates": 20,
      "max_evidence_packet_tokens": 8192,
      "max_wall_clock_seconds": 900
    },
    "standard": {
      "max_search_branches": 3,
      "results_per_branch": 25,
      "max_extraction_attempts": 18,
      "max_successful_extractions": 12,
      "max_adaptive_cycles": 3,
      "max_llm_calls": 10,
      "max_input_tokens": 49152,
      "max_output_tokens": 12288,
      "max_retrieval_candidates": 80,
      "max_reranker_candidates": 40,
      "max_evidence_packet_tokens": 12288,
      "max_wall_clock_seconds": 1800
    },
    "intensive": {
      "max_search_branches": 5,
      "results_per_branch": 40,
      "max_extraction_attempts": 36,
      "max_successful_extractions": 25,
      "max_adaptive_cycles": 4,
      "max_llm_calls": 16,
      "max_input_tokens": 65536,
      "max_output_tokens": 16384,
      "max_retrieval_candidates": 160,
      "max_reranker_candidates": 80,
      "max_evidence_packet_tokens": 16384,
      "max_wall_clock_seconds": 3600
    }
  },
  "tier_rules": [
    {
      "rule_id": "tier.high_risk",
      "minimum_tier": "intensive",
      "condition": "risk_level == high"
    },
    {
      "rule_id": "tier.expected_disagreement",
      "minimum_tier": "intensive",
      "condition": "contradiction_requirements > 0"
    },
    {
      "rule_id": "tier.large_semantic_scope",
      "minimum_tier": "intensive",
      "condition": "questions + claims >= 6"
    },
    {
      "rule_id": "tier.broad_source_requirements",
      "minimum_tier": "intensive",
      "condition": "required_source_minimum >= 5"
    },
    {
      "rule_id": "tier.medium_risk",
      "minimum_tier": "standard",
      "condition": "risk_level == medium"
    },
    {
      "rule_id": "tier.freshness_sensitive",
      "minimum_tier": "standard",
      "condition": "freshness_requirements > 0"
    },
    {
      "rule_id": "tier.multi_part_scope",
      "minimum_tier": "standard",
      "condition": "questions + claims >= 3"
    },
    {
      "rule_id": "tier.corroboration_required",
      "minimum_tier": "standard",
      "condition": "corroboration_requirements > 0"
    },
    {
      "rule_id": "tier.multiple_source_classes",
      "minimum_tier": "standard",
      "condition": "required_source_minimum >= 3"
    },
    {
      "rule_id": "tier.archetype_floor",
      "minimum_tier": "standard",
      "condition": "research_archetype in [breaking_news, legislative_legal, academic_debate]"
    }
  ]
}
