  +        CATALOG_CLAIM_TYPE,
  +        CATALOG_ASSESSMENT_TYPE,
  +    )
  +)
  +
  +# Supported Catalog v5 schema versions
  +SUPPORTED_SCHEMA_VERSIONS = frozenset({5})
