#!/usr/bin/env bash
# frun — explicit Firecrawl research-run lifecycle.
set -euo pipefail
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
if [[ "${FIRECRAWL_RESEARCH_AUTO_ENV:-1}" == "1" && -r "$SCRIPT_DIR/research-env" ]]; then
  source "$SCRIPT_DIR/research-env"
fi
PERSIST_MODE="${FIRECRAWL_RESEARCH_PERSIST:-auto}"
case "$PERSIST_MODE" in
  on) [[ -n "${DATABASE_URL:-}" ]] || { echo "ERROR: persistence is on but DATABASE_URL is unavailable" >&2; exit 1; }; DB_ACTIVE=1 ;;
  auto) [[ -n "${DATABASE_URL:-}" ]] && DB_ACTIVE=1 || DB_ACTIVE=0 ;;
  off) DB_ACTIVE=0 ;;
  *) echo "ERROR: FIRECRAWL_RESEARCH_PERSIST must be auto, on, or off" >&2; exit 2 ;;
esac
PYTHON="${FIRECRAWL_RESEARCH_PYTHON:-python3}"
ADAPTER_MODE="${FIRECRAWL_LEGACY_ADAPTER_MODE:-compatibility}"
case "$ADAPTER_MODE" in
  compatibility) ;;
  shadow|authoritative)
    [[ -n "${DATABASE_URL:-}" ]] || { echo "ERROR: $ADAPTER_MODE adapter mode requires DATABASE_URL" >&2; exit 1; }
    DB_ACTIVE=1
    ;;
  *) echo "ERROR: FIRECRAWL_LEGACY_ADAPTER_MODE must be compatibility, shadow, or authoritative" >&2; exit 2 ;;
esac
preflight_database() {
  if [[ "$DB_ACTIVE" == "1" ]]; then
    "$SCRIPT_DIR/research-db" ingest-ready >/dev/null
  fi
}
case "${1:-}" in
  start)
    shift
    objective="${1:-}"
    preflight_database
    output="$("$PYTHON" "$SCRIPT_DIR/invocation_catalog.py" run-start "$@")"
    run_id="$(printf '%s\n' "$output" | tail -n 1)"
    if [[ "$DB_ACTIVE" == "1" ]]; then
      if ! "$SCRIPT_DIR/research-db" run-start "$run_id" "$objective" >/dev/null; then
        printf '%s\n' "ERROR: Catalog run $run_id exists but PostgreSQL mirroring failed." >&2
        printf 'RECOVER:' >&2
        printf ' %q' "$SCRIPT_DIR/research-db" run-start "$run_id" "$objective" >&2
        printf '\n' >&2
        printf '%s\n' "$run_id" >&2
        exit 1
      fi
    fi
    "$PYTHON" "$SCRIPT_DIR/legacy_adapter.py" \
      --entry-point frun --action start --status complete \
      --research-run-id "$run_id" \
      --idempotency-key "legacy-adapter:$run_id:frun:start:{workflow_revision}" >/dev/null
    printf '%s\n' "$output"
    ;;
  finish)
    shift
    run_id="${1:-}"
    outcome=""
    source_manifest=""
    answer_file=""
    previous=""
    auto_audit=0
    catalog_args=()
    for argument in "$@"; do
      if [[ "$argument" == "--auto-audit" ]]; then
        auto_audit=1
        continue
      fi
      [[ "$previous" == "--outcome" ]] && outcome="$argument"
      [[ "$previous" == "--source-manifest" ]] && source_manifest="$argument"
      [[ "$previous" == "--answer-file" ]] && answer_file="$argument"
      catalog_args+=("$argument")
      previous="$argument"
    done
    output="$("$PYTHON" "$SCRIPT_DIR/invocation_catalog.py" run-finish "${catalog_args[@]}")"
    if [[ "$DB_ACTIVE" == "1" ]]; then
      db_args=(run-finish "$run_id" --outcome "$outcome")
      if [[ -n "$source_manifest" ]]; then
        db_args+=(--source-manifest-sha256 "$(sha256sum "$source_manifest" | awk '{print $1}')")
      fi
      if [[ -n "$answer_file" ]]; then
        db_args+=(--answer-sha256 "$(sha256sum "$answer_file" | awk '{print $1}')")
      fi
      "$SCRIPT_DIR/research-db" "${db_args[@]}" >/dev/null
    fi
    "$PYTHON" "$SCRIPT_DIR/legacy_adapter.py" \
      --entry-point frun --action finish --status complete \
      --research-run-id "$run_id" \
      --idempotency-key "legacy-adapter:$run_id:frun:finish:$outcome:{workflow_revision}" >/dev/null
    printf '%s\n' "$output"
    if [[ "$auto_audit" == "1" ]]; then
      "$PYTHON" "$SCRIPT_DIR/invocation_catalog.py" audit "$run_id"
    fi
    ;;
  reopen)
    shift
    run_id="${1:-}"
    preflight_database
    "$PYTHON" "$SCRIPT_DIR/invocation_catalog.py" run-reopen "$@"
    if [[ "$DB_ACTIVE" == "1" ]]; then
      if ! "$SCRIPT_DIR/research-db" run-reopen "$@" >/dev/null; then
        printf '%s\n' "ERROR: Catalog run $run_id reopened but PostgreSQL mirroring failed." >&2
        printf 'RECOVER:' >&2
        printf ' %q' "$SCRIPT_DIR/research-db" run-reopen "$@" >&2
        printf '\n' >&2
        exit 1
      fi
    fi
    "$PYTHON" "$SCRIPT_DIR/legacy_adapter.py" \
      --entry-point frun --action reopen --status complete \
      --research-run-id "$run_id" \
      --idempotency-key "legacy-adapter:$run_id:frun:reopen:{workflow_revision}" >/dev/null
    ;;
  annotate) shift; exec "$PYTHON" "$SCRIPT_DIR/invocation_catalog.py" run-annotate "$@" ;;
  status|show) shift; exec "$PYTHON" "$SCRIPT_DIR/invocation_catalog.py" run-show "$@" ;;
  verify) shift; exec "$PYTHON" "$SCRIPT_DIR/invocation_catalog.py" verify "$@" ;;
  audit) shift; exec "$PYTHON" "$SCRIPT_DIR/invocation_catalog.py" audit "$@" ;;
  audit-status) shift; exec "$PYTHON" "$SCRIPT_DIR/invocation_catalog.py" audit-status "$@" ;;
  aggregate) shift; exec "$PYTHON" "$SCRIPT_DIR/invocation_catalog.py" aggregate "$@" ;;
  recompute) shift; exec "$PYTHON" "$SCRIPT_DIR/invocation_catalog.py" recompute "$@" ;;
  migrate) shift; exec "$PYTHON" "$SCRIPT_DIR/invocation_catalog.py" migrate "$@" ;;
  compare) shift; exec "$PYTHON" "$SCRIPT_DIR/invocation_catalog.py" compare "$@" ;;
  purge) shift; exec "$PYTHON" "$SCRIPT_DIR/invocation_catalog.py" purge "$@" ;;
  *) echo "Usage: frun {start <objective> [--profile PROFILE]|finish <fr_id> --outcome OUTCOME [--source-manifest FILE] [--answer-file FILE] [--auto-audit]|reopen <fr_id> --reason TEXT|annotate <fr_id> --type TYPE --reason TEXT|status <fr_id>|verify <id>|audit <id> [--llm PROVIDER] [--stages LIST]|audit-status <id>|aggregate|recompute <id>|migrate [--apply]|compare <fr_id>...|purge [filters] [--force]}" >&2; exit 2 ;;
esac
