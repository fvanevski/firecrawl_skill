#!/usr/bin/env bash
# frun — explicit Firecrawl research-run lifecycle.
#
# All commands are routed through PostgreSQL (authoritative) with
# derived filesystem compatibility exports.  When PostgreSQL is
# unavailable the legacy filesystem path is used with a deprecation
# warning.
set -euo pipefail
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
if [[ "${FIRECRAWL_RESEARCH_AUTO_ENV:-1}" == "1" && -r "$SCRIPT_DIR/research-env" ]]; then
  source "$SCRIPT_DIR/research-env"
fi
PERSIST_MODE="${FIRECRAWL_RESEARCH_PERSIST:-auto}"
case "$PERSIST_MODE" in
  on) [[ -n "${DATABASE_URL:-}" ]] || { echo "ERROR: persistence is on but DATABASE_URL is unavailable" >&2; exit 1; }; DB_ACTIVE=1 ;;
  auto) [[ -n "${DATABASE_URL:-}" ]] && DB_ACTIVE=1 || DB_ACTIVE=0 ;;
  off) DB_ACTIVE=0 ;;
  *) echo "ERROR: FIRECRAWL_RESEARCH_PERSIST must be auto, on, or off" >&2; exit 2 ;;
esac
PYTHON="${FIRECRAWL_RESEARCH_PYTHON:-python3}"
ADAPTER_MODE="${FIRECRAWL_LEGACY_ADAPTER_MODE:-compatibility}"
case "$ADAPTER_MODE" in
  compatibility) ;;
  shadow|authoritative)
    [[ -n "${DATABASE_URL:-}" ]] || { echo "ERROR: $ADAPTER_MODE adapter mode requires DATABASE_URL" >&2; exit 1; }
    DB_ACTIVE=1
    ;;
  *) echo "ERROR: FIRECRAWL_LEGACY_ADAPTER_MODE must be compatibility, shadow, or authoritative" >&2; exit 2 ;;
esac
preflight_database() {
  if [[ "$DB_ACTIVE" == "1" ]]; then
    "$SCRIPT_DIR/research-db" ingest-ready >/dev/null
  fi
}
# Emit a one-shot deprecation warning when falling back to the legacy
# filesystem catalog.  We track it in a temp file so the message only
# appears once per invocation.
_deprecation_warning_shown=0
_deprecation_warn() {
  if [[ "$_deprecation_warning_shown" == "0" ]]; then
    printf '%s\n' "WARNING: falling back to legacy filesystem catalog; PostgreSQL commands are deprecated and will be removed in a future release" >&2
    _deprecation_warning_shown=1
  fi
}
_compat_export_events() {
  local run_id="$1"
  if [[ "${FIRECRAWL_CATALOG_DISABLED:-}" != "1" ]]; then
    "$PYTHON" "$SCRIPT_DIR/catalog_v5.py" export-events-to-fs --run-id "$run_id" >/dev/null 2>&1 || true
  fi
}
case "${1:-}" in
  start)
    shift
    objective="${1:-}"
    preflight_database
    if [[ "$DB_ACTIVE" == "1" ]]; then
      run_id="$("$SCRIPT_DIR/research-db" run-start "$objective")"
      if [[ -z "$run_id" ]]; then
        printf '%s\n' "ERROR: PostgreSQL run-start failed" >&2
        exit 1
      fi
      # Derive filesystem catalog record from committed PostgreSQL state
      _compat_export_events "$run_id"
    else
      _deprecation_warn
      output="$("$PYTHON" "$SCRIPT_DIR/invocation_catalog.py" run-start "$@")"
      run_id="$(printf '%s\n' "$output" | tail -n 1)"
    fi
    if [[ "$DB_ACTIVE" == "1" ]]; then
      "$PYTHON" "$SCRIPT_DIR/legacy_adapter.py" \
        --entry-point frun --action start --status complete \
        --research-run-id "$run_id" \
        --idempotency-key "legacy-adapter:$run_id:frun:start:{workflow_revision}" >/dev/null
    fi
    printf '%s\n' "${run_id:-$output}"
    ;;
  finish)
    shift
    run_id="${1:-}"
    outcome=""
    source_manifest=""
    answer_file=""
    previous=""
    auto_audit=0
    for argument in "$@"; do
      if [[ "$argument" == "--auto-audit" ]]; then
        auto_audit=1
        continue
      fi
      [[ "$previous" == "--outcome" ]] && outcome="$argument"
      [[ "$previous" == "--source-manifest" ]] && source_manifest="$argument"
      [[ "$previous" == "--answer-file" ]] && answer_file="$argument"
      previous="$argument"
    done
    if [[ "$DB_ACTIVE" == "1" ]]; then
      db_args=(run-finish "$run_id" --outcome "$outcome")
      if [[ -n "$source_manifest" ]]; then
        db_args+=(--source-manifest-sha256 "$(sha256sum "$source_manifest" | awk '{print $1}')")
      fi
      if [[ -n "$answer_file" ]]; then
        db_args+=(--answer-sha256 "$(sha256sum "$answer_file" | awk '{print $1}')")
      fi
      "$SCRIPT_DIR/research-db" "${db_args[@]}" >/dev/null
      # Derive filesystem catalog record from committed PostgreSQL state
      _compat_export_events "$run_id"
    else
      _deprecation_warn
      catalog_args=()
      for argument in "$@"; do
        [[ "$argument" != "--auto-audit" ]] && catalog_args+=("$argument")
      done
      "$PYTHON" "$SCRIPT_DIR/invocation_catalog.py" run-finish "${catalog_args[@]}" >/dev/null
    fi
    if [[ "$DB_ACTIVE" == "1" ]]; then
      "$PYTHON" "$SCRIPT_DIR/legacy_adapter.py" \
        --entry-point frun --action finish --status complete \
        --research-run-id "$run_id" \
        --idempotency-key "legacy-adapter:$run_id:frun:finish:$outcome:{workflow_revision}" >/dev/null
    fi
    printf '%s\n' "${run_id:-}"
    if [[ "$auto_audit" == "1" ]]; then
      if [[ "$DB_ACTIVE" == "1" ]]; then
        "$PYTHON" "$SCRIPT_DIR/catalog_v5.py" audit "$run_id"
      else
        _deprecation_warn
        "$PYTHON" "$SCRIPT_DIR/catalog_v5.py" audit "$run_id"
      fi
    fi
    ;;
  reopen)
    shift
    run_id="${1:-}"
    preflight_database
    if [[ "$DB_ACTIVE" == "1" ]]; then
      "$SCRIPT_DIR/research-db" run-reopen "$@" >/dev/null
      # Derive filesystem catalog record from committed PostgreSQL state
      _compat_export_events "$run_id"
    else
      _deprecation_warn
      "$PYTHON" "$SCRIPT_DIR/invocation_catalog.py" run-reopen "$@"
    fi
    if [[ "$DB_ACTIVE" == "1" ]]; then
      "$PYTHON" "$SCRIPT_DIR/legacy_adapter.py" \
        --entry-point frun --action reopen --status complete \
        --research-run-id "$run_id" \
        --idempotency-key "legacy-adapter:$run_id:frun:reopen:{workflow_revision}" >/dev/null
    fi
    ;;
  annotate)
    shift
    if [[ "$DB_ACTIVE" == "1" ]]; then
      "$SCRIPT_DIR/research-db" run-annotate "$@"
    else
      _deprecation_warn
      "$PYTHON" "$SCRIPT_DIR/catalog_v5.py" run-annotate "$@"
    fi
    ;;
  status|show)
    shift
    if [[ "$DB_ACTIVE" == "1" ]]; then
      "$SCRIPT_DIR/research-db" run-status "$@"
    else
      _deprecation_warn
      "$PYTHON" "$SCRIPT_DIR/catalog_v5.py" run-show "$@"
    fi
    ;;
  verify)
    shift
    if [[ "$DB_ACTIVE" == "1" ]]; then
      "$SCRIPT_DIR/research-db" run-verify "$@"
    else
      _deprecation_warn
      "$PYTHON" "$SCRIPT_DIR/catalog_v5.py" verify "$@"
    fi
    ;;
  audit)
    shift
    if [[ "$DB_ACTIVE" == "1" ]]; then
      # Extract --target-hash if provided; otherwise require it
      target_hash=""
      remaining_args=()
      for arg in "$@"; do
        if [[ "$arg" == --target-hash ]]; then
          target_hash="${remaining_args[*]:-}"
          break
        fi
        remaining_args+=("$arg")
      done
      if [[ -n "$target_hash" ]]; then
        "$SCRIPT_DIR/research-db" run-audit "$@"
      else
        echo "WARNING: PostgreSQL audit requires --target-hash; use catalog_v5.py audit for auto-packet building" >&2
        "$PYTHON" "$SCRIPT_DIR/catalog_v5.py" audit "$@"
      fi
    else
      _deprecation_warn
      "$PYTHON" "$SCRIPT_DIR/catalog_v5.py" audit "$@"
    fi
    ;;
  audit-status)
    shift
    if [[ "$DB_ACTIVE" == "1" ]]; then
      "$SCRIPT_DIR/research-db" audit-status "$@"
    else
      _deprecation_warn
      "$PYTHON" "$SCRIPT_DIR/catalog_v5.py" audit-status "$@"
    fi
    ;;
  compare)
    shift
    if [[ "$DB_ACTIVE" == "1" ]]; then
      "$SCRIPT_DIR/research-db" run-compare "$@"
    else
      _deprecation_warn
      "$PYTHON" "$SCRIPT_DIR/catalog_v5.py" compare "$@"
    fi
    ;;
  export)
    shift
    run_id="${1:-}"
    if [[ "$DB_ACTIVE" == "1" ]]; then
      target_dir="${2:-}"
      if [[ -z "$target_dir" ]]; then
        echo "ERROR: export requires a target directory" >&2
        exit 1
      fi
      "$SCRIPT_DIR/research-db" catalog-export run "$run_id" --target-dir "$target_dir"
    else
      _deprecation_warn
      echo "ERROR: export requires PostgreSQL (FIRECRAWL_RESEARCH_PERSIST=on)" >&2
      exit 1
    fi
    ;;
  aggregate) shift; exec "$PYTHON" "$SCRIPT_DIR/catalog_v5.py" aggregate "$@" ;;
  recompute) shift; exec "$PYTHON" "$SCRIPT_DIR/catalog_v5.py" recompute "$@" ;;
  migrate) shift; exec "$PYTHON" "$SCRIPT_DIR/catalog_v5.py" migrate "$@" ;;
  purge) shift; exec "$PYTHON" "$SCRIPT_DIR/catalog_v5.py" purge "$@" ;;
  *) echo "Usage: frun {start <objective> [--mode MODE]|finish <fr_id> --outcome OUTCOME [--source-manifest FILE] [--answer-file FILE] [--auto-audit]|reopen <fr_id> --reason TEXT|annotate <fr_id> --type TYPE --reason TEXT|status <fr_id>|verify <id>|audit <id> [--llm PROVIDER] [--stages LIST]|audit-status <id>|compare <fr_id>...|export <fr_id> <target-dir>|aggregate|recompute <id>|migrate [--apply]|purge [filters] [--force]}" >&2; exit 2 ;;
esac
